DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Для PostgreSQL задайте DB_HOST (или явно DB_ENGINE) — иначе Django использует только SQLite (db.sqlite3).
# DB_ENGINE=django.db.backends.postgresql
DB_NAME=campaigns_matrix
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Файлы в S3 (REG.RU Cloud и др.): https://reg.cloud/support/cloud/obyektnoye-khranilishche-s3/
# Секреты только в .env, не коммитить. При утечке ключа — отозвать в панели и выпустить новый.
# DJANGO_USE_S3=true
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=matrix-campaings
# AWS_S3_ENDPOINT_URL=https://s3.regru.cloud
# AWS_S3_REGION_NAME=ru-msk
# AWS_S3_ADDRESSING_STYLE=path
# Опционально: виртуальный хост для публичных URL
# AWS_S3_CUSTOM_DOMAIN=matrix-campaings.website.regru.cloud
# Подписанные ссылки на файлы (приватный бакет). По умолчанию в settings = true, если не задано.
# AWS_QUERYSTRING_AUTH=true
# Срок жизни ссылки в секундах (по умолчанию 86400 = 24 ч)
# AWS_QUERYSTRING_EXPIRE=86400
# Альтернатива: публичное чтение объектов (без подписи) — не для секретных файлов
# AWS_DEFAULT_ACL=public-read
# AWS_QUERYSTRING_AUTH=false
